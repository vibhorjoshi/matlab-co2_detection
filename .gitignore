# ============================================================
# .gitignore — MATLAB project (CO2 hyperspectral detection)
# ============================================================

# ---------- MATLAB auto-save and temporary files ----------
*.asv           # Autosave backup files
*.m~            # Emacs-style backups

# ---------- MATLAB compiled / binary outputs ----------
*.mex*          # MEX files (all platforms: .mexa64, .mexmaci64, .mexw64)
*.obj           # Object files from MEX compilation
*.exp
*.lib
*.ilk
*.pdb
*.sbr

# ---------- Simulink / Stateflow generated code ----------
slprj/
sfprj/
codegen/
*.slxc
*.ssc

# ---------- Large data files (do NOT commit to repo) ----------
# Raw AVIRIS data cubes — too large for GitHub (> 100 MB per file)
*.hdr
*.img
*.bin
*.dat
*.bsq
*.bil
*.bip

# Processed results — regenerated by running main_pipeline.m
proposed_results.mat

# ---------- Output figures (regenerated by pipeline) ----------
updated_output_file/*.png
updated_output_file/*.jpg
updated_output_file/*.csv

# EXCEPTION: keep the output folder itself
!updated_output_file/.gitkeep

# ---------- MATLAB preferences and history ----------
*.mlx.autosave
matlab.prf
StarterCode/

# ---------- R2021b+ project files (optional, keep if used) ----------
# *.prj

# ---------- OS generated files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ---------- IDE / editor ----------
.vscode/
*.code-workspace
.idea/
